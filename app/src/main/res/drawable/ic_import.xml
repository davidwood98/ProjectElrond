<!-- Leap · Import (arrow into a tray). Exact geometry from the Claude Design handoff `ic-import`,
     used by the Library top-bar import button. Single-colour line art, tinted at the call site. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Arrow shaft. -->
    <path
        android:pathData="M12 3v11"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
    <!-- Downward arrowhead. -->
    <path
        android:pathData="M8 10.5l4 4 4 -4"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Tray. -->
    <path
        android:pathData="M4 16.5v2.5a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2.5"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
