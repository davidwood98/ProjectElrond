    <path
        android:pathData="M13 4H7A3 3 0 0 0 4 7V17A3 3 0 0 0 7 20H12"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <path android:pathData="M8 9h5" android:strokeColor="#FF000000" android:strokeWidth="2" android:strokeLineCap="round" />
    <path android:pathData="M8 12.5h3.5" android:strokeColor="#FF000000" android:strokeWidth="2" android:strokeLineCap="round" />
    <!-- Pen, diagonal across the lower-right. -->
    <path
        android:pathData="M12.6 20l0.8,-2.9 6.3,-6.3 2.1 2.1 -6.3 6.3z"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <path
        android:pathData="M17.5 12.4l2.1 2.1"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <path
        android:pathData="M12.6 20l1.8,-0.5 -1.3,-1.3z"
        android:fillColor="#FF000000" />
</vector>
