<!-- Leap action · New note (notepad + pen). Exact geometry from the Claude Design handoff
     `ic-notepad` (the create-note FAB glyph). Single-colour line art, tinted at the call site. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Notepad body, top-right left open for the pen. -->
    <path
        android:pathData="M14.5 4H7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7.5"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Three ruled text lines. -->
    <path
        android:pathData="M8.5 9h4.5 M8.5 12.5h6 M8.5 16h3.5"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
    <!-- Pen / edit nib, top-right diagonal. -->
    <path
        android:pathData="M18.7 3.1a1.6 1.6 0 0 1 2.2 2.2l-5.6 5.6 -2.9 0.7 0.7 -2.9z"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
