<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Calendar permissions are deliberately NOT declared yet (security audit):
         add READ_CALENDAR/WRITE_CALENDAR in the same change that ships feature 7. -->

    <!-- Stylus is the primary input but the app must still install without one -->
    <uses-feature
        android:name="android.hardware.touchscreen.stylus"
        android:required="false" />

    <!-- allowBackup=false: note content stays on-device, never in cloud backups. -->
    <application
        android:name=".ElrondApplication"
        android:allowBackup="false"
        android:usesCleartextTraffic="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProjectElrond">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
